# Email Configuration
# Replace with your actual Gmail and app password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# Example:
# EMAIL_USER=johndoe@gmail.com
# EMAIL_PASS=abcd efgh ijkl mnop

# Database Configuration
# MySQL connection settings (Aiven, PlanetScale, etc.)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=employee_system
DB_PORT=3306

# Database Mode
# Set to 'true' to use MySQL database instead of data.json
# In production (NODE_ENV=production), MySQL is automatically enabled
USE_DATABASE=false

# Environment (development or production)
NODE_ENV=development
