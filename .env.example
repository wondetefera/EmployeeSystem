# ============================================================================
# Email Configuration
# ============================================================================
# Gmail SMTP settings for sending email notifications
# Get App Password from: https://myaccount.google.com/apppasswords
# (Requires 2-Factor Authentication enabled)

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# Example (do NOT use these values):
# EMAIL_USER=johndoe@gmail.com
# EMAIL_PASS=abcd efgh ijkl mnop


# ============================================================================
# Database Configuration - MySQL
# ============================================================================
# MySQL connection parameters for persistent data storage
# For detailed setup instructions, see: database-setup.md

# Database Host/Server Address
# LOCAL DEVELOPMENT: localhost (or 127.0.0.1)
# PRODUCTION (Render): Copy from Render MySQL dashboard → Connections
DB_HOST=localhost

# Database Username
# LOCAL DEVELOPMENT: root or emp_system_user
# PRODUCTION (Render): Copy from Render MySQL dashboard → Connections
DB_USER=root

# Database Password
# LOCAL DEVELOPMENT: Your MySQL root password or custom user password
# PRODUCTION (Render): Copy from Render MySQL dashboard → Connections
# ⚠️ SECURITY: Never commit actual passwords to version control!
DB_PASSWORD=your-database-password

# Database Name
# This is the name of the database that stores all application data
# Usually: employee_system
DB_NAME=employee_system

# Database Port
# Standard MySQL port: 3306
# LOCAL DEVELOPMENT: 3306 (default)
# PRODUCTION (Render): Check Render dashboard (usually 3306 or custom)
DB_PORT=3306


# ============================================================================
# Environment Configuration
# ============================================================================
# Environment determines connection behavior and error handling

# NODE_ENV Options:
# - development: Local development with MySQL on localhost
#   • Allows missing environment variables (uses defaults)
#   • Continues running if database connection fails
#   • Verbose error logging for debugging
# 
# - production: Render.com deployment or external MySQL server
#   • Requires all database environment variables to be set
#   • Exits process if database connection fails (triggers container restart)
#   • Sanitized error messages (no internal details to clients)
NODE_ENV=development


# ============================================================================
# Example Configurations
# ============================================================================

# EXAMPLE 1: Local Development (Docker MySQL)
# ────────────────────────────────────────────
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=employee_system
# DB_PORT=3306
# NODE_ENV=development

# EXAMPLE 2: Local Development (Native MySQL)
# ─────────────────────────────────────────────
# DB_HOST=localhost
# DB_USER=emp_system_user
# DB_PASSWORD=your_secure_password
# DB_NAME=employee_system
# DB_PORT=3306
# NODE_ENV=development

# EXAMPLE 3: Production (Render.com MySQL)
# ───────────────────────────────────────
# DB_HOST=mysql-abc.render.com
# DB_USER=prod_user
# DB_PASSWORD=generated-password-from-render
# DB_NAME=employee_system
# DB_PORT=3306
# NODE_ENV=production
# EMAIL_USER=system@company.com
# EMAIL_PASS=generated-gmail-app-password


# ============================================================================
# Setup Checklist
# ============================================================================
# Before running the application:
#
# ✓ Update this file with your actual values
# ✓ Save this file as .env (not .env.example)
# ✓ Never commit .env file to version control
# ✓ Verify database exists and is accessible
# ✓ Run: node migrate-to-mysql.js (to transfer data from data.json)
# ✓ For detailed instructions, see: database-setup.md

# ============================================================================
# Security Notes
# ============================================================================
# • .env is in .gitignore - your credentials won't be committed
# • Change default database passwords before production deployment
# • Use strong passwords (minimum 16 characters recommended)
# • On Render: Set environment variables via Dashboard → Environment tab
# • Never share .env file or paste its contents online
# • Rotate passwords regularly for production databases
